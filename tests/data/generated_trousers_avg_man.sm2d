<?xml version="1.0" encoding="UTF-8"?>
<pattern>
    <!--Pattern created with pattern-forge (Seamly2D-compatible).-->
    <version>0.6.8</version>
    <unit>cm</unit>
    <description>Classic trouser block generated by pattern-forge. Variables (Ctrl+T) drive the geometry.</description>
    <notes />
    <measurements />
    <increments>
        <increment description="waist + ease" formula="86" name="#WaistCircumference" />
        <increment description="hip + ease" formula="100" name="#HipCircumference" />
        <increment description="waist to floor" formula="107" name="#WaistHeight" />
        <increment description="crotch to floor" formula="83" name="#CrotchHeight" />
        <increment description="knee to floor" formula="50" name="#KneeHeight" />
        <increment description="hip line height (crotch + hip/20 + 3)" formula="91" name="#HipLineHeight" />
        <increment description="front width at hip" formula="25" name="#FrontPanelWidth" />
        <increment description="crease to CF at hip" formula="9.9" name="#FrontPanelWidthFront" />
        <increment description="front crotch extension" formula="6" name="#FrontCrotchHookWidth" />
        <increment description="back width at hip" formula="27" name="#BackPanelWidth" />
        <increment description="crease to CB at hip" formula="6.75" name="#BackPanelWidthBack" />
        <increment description="knee circumference (style)" formula="52" name="#KneeCircumference" />
        <increment description="hem circumference (style)" formula="42" name="#AnkleCircumference" />
        <increment description="front dart intake" formula="2" name="#FrontDartWidth" />
        <increment description="front dart length" formula="6" name="#FrontDartDepth" />
        <increment description="back dart intake" formula="3" name="#BackDartWidth" />
        <increment description="back dart length" formula="11" name="#BackDartDepth" />
        <increment description="CB shift at waist" formula="2" name="#BackCenterShift" />
        <increment description="CB rise above waist line" formula="2" name="#BackRise" />
        <increment description="waistband width" formula="4" name="#WaistBandWidth" />
    </increments>
    <draftBlock name="Trousers">
        <calculation>
            <point id="1" mx="0.5" my="1" name="Heel" type="single" x="0" y="0" />
            <point angle="90" basePoint="1" id="2" length="#WaistHeight" lineColor="black" lineType="dashLine" mx="0.5" my="-1.5" name="WaistLine" type="endLine" />
            <point firstPoint="1" id="3" length="#CrotchHeight" lineColor="black" lineType="none" mx="0.5" my="-1.5" name="CrotchLine" secondPoint="2" type="alongLine" />
            <point firstPoint="1" id="4" length="#HipLineHeight" lineColor="black" lineType="none" mx="0.5" my="-1.5" name="HipLine" secondPoint="2" type="alongLine" />
            <point firstPoint="1" id="5" length="#KneeHeight" lineColor="black" lineType="none" mx="0.5" my="-1.5" name="KneeLine" secondPoint="2" type="alongLine" />
            <point angle="0" basePoint="1" id="6" length="(#AnkleCircumference/2 - 1)/2" lineColor="black" lineType="none" mx="0.5" my="-1.5" name="HemFIn" type="endLine" />
            <point angle="180" basePoint="1" id="7" length="(#AnkleCircumference/2 - 1)/2" lineColor="black" lineType="none" mx="0.5" my="-1.5" name="HemFOut" type="endLine" />
            <point angle="0" basePoint="5" id="8" length="(#KneeCircumference/2 - 1)/2" lineColor="black" lineType="none" mx="0.5" my="-1.5" name="KneeFIn" type="endLine" />
            <point angle="180" basePoint="5" id="9" length="(#KneeCircumference/2 - 1)/2" lineColor="black" lineType="none" mx="0.5" my="-1.5" name="KneeFOut" type="endLine" />
            <point angle="0" basePoint="4" id="10" length="#FrontPanelWidthFront" lineColor="black" lineType="none" mx="0.5" my="-1.5" name="HipFCF" type="endLine" />
            <point angle="180" basePoint="4" id="11" length="#FrontPanelWidth - #FrontPanelWidthFront" lineColor="black" lineType="none" mx="0.5" my="-1.5" name="HipFSide" type="endLine" />
            <point angle="0" basePoint="3" id="12" length="#FrontPanelWidthFront + #FrontCrotchHookWidth" lineColor="black" lineType="none" mx="0.5" my="-1.5" name="CrotchPointF" type="endLine" />
            <point firstPoint="10" id="13" lineColor="black" lineType="none" mx="0.5" my="-1.5" name="WaistFCF" secondPoint="2" type="intersectXY" />
            <point angle="180" basePoint="2" id="14" length="#WaistCircumference/4 + #FrontDartWidth - #FrontPanelWidthFront" lineColor="black" lineType="none" mx="0.5" my="-1.5" name="WaistFSide" type="endLine" />
            <line firstPoint="14" id="15" lineColor="green" lineType="dotLine" secondPoint="13" />
            <point firstPoint="14" id="16" length="Line_WaistFSide_WaistFCF/2" lineColor="black" lineType="none" mx="0.5" my="-1.5" name="DartCenterF" secondPoint="13" type="alongLine" />
            <point firstPoint="16" id="17" length="#FrontDartWidth/2" lineColor="black" lineType="none" mx="0.5" my="-1.5" name="DartFL1" secondPoint="14" type="alongLine" />
            <point firstPoint="16" id="18" length="#FrontDartWidth/2" lineColor="black" lineType="none" mx="0.5" my="-1.5" name="DartFL2" secondPoint="13" type="alongLine" />
            <point angle="180" firstPoint="16" id="19" length="#FrontDartDepth" lineColor="black" lineType="none" mx="0.5" my="-1.5" name="DartTipF" secondPoint="13" type="normal" />
            <point angle="270" basePoint="10" id="20" length="(#HipLineHeight - #CrotchHeight)/2" lineColor="black" lineType="none" mx="0.5" my="-1.5" name="CtrlFCrotch1" type="endLine" />
            <point angle="180" basePoint="12" id="21" length="#FrontCrotchHookWidth/1.5" lineColor="black" lineType="none" mx="0.5" my="-1.5" name="CtrlFCrotch2" type="endLine" />
            <spline color="black" id="22" point1="10" point2="20" point3="21" point4="12" type="cubicBezier" />
            <point angle="270" basePoint="14" id="23" length="(#WaistHeight - #HipLineHeight)/2" lineColor="black" lineType="none" mx="0.5" my="-1.5" name="CtrlFSide1" type="endLine" />
            <point angle="90" basePoint="11" id="24" length="(#WaistHeight - #HipLineHeight)/3" lineColor="black" lineType="none" mx="0.5" my="-1.5" name="CtrlFSide2" type="endLine" />
            <spline color="black" id="25" point1="14" point2="23" point3="24" point4="11" type="cubicBezier" />
            <line firstPoint="13" id="26" lineColor="black" lineType="solidLine" secondPoint="10" />
            <line firstPoint="8" id="27" lineColor="black" lineType="solidLine" secondPoint="12" />
            <line firstPoint="11" id="28" lineColor="black" lineType="solidLine" secondPoint="9" />
            <line firstPoint="9" id="29" lineColor="black" lineType="solidLine" secondPoint="7" />
            <line firstPoint="7" id="30" lineColor="black" lineType="solidLine" secondPoint="6" />
            <line firstPoint="6" id="31" lineColor="black" lineType="solidLine" secondPoint="8" />
            <point angle="0" basePoint="1" id="47" length="(#AnkleCircumference/2 + 1)/2" lineColor="black" lineType="none" mx="0.5" my="-1.5" name="HemBIn" type="endLine" />
            <point angle="180" basePoint="1" id="48" length="(#AnkleCircumference/2 + 1)/2" lineColor="black" lineType="none" mx="0.5" my="-1.5" name="HemBOut" type="endLine" />
            <point angle="0" basePoint="5" id="49" length="(#KneeCircumference/2 + 1)/2" lineColor="black" lineType="none" mx="0.5" my="-1.5" name="KneeBIn" type="endLine" />
            <point angle="180" basePoint="5" id="50" length="(#KneeCircumference/2 + 1)/2" lineColor="black" lineType="none" mx="0.5" my="-1.5" name="KneeBOut" type="endLine" />
            <point angle="0" basePoint="4" id="51" length="#BackPanelWidthBack" lineColor="black" lineType="none" mx="0.5" my="-1.5" name="HipBCB" type="endLine" />
            <point angle="180" basePoint="4" id="52" length="#BackPanelWidth - #BackPanelWidthBack" lineColor="black" lineType="none" mx="0.5" my="-1.5" name="HipBSide" type="endLine" />
            <point firstPoint="49" id="53" length="Line_KneeFIn_CrotchPointF" lineColor="black" lineType="none" mx="0.5" my="-1.5" name="CrotchPointB" secondPoint="51" type="alongLine" />
            <point angle="0" basePoint="2" id="54" length="#BackCenterShift" lineColor="black" lineType="dotLine" mx="0.5" my="-1.5" name="BackWaistBase" type="endLine" />
            <point angle="90" basePoint="54" id="55" length="#BackRise" lineColor="black" lineType="none" mx="0.5" my="-1.5" name="WaistBCB" type="endLine" />
            <point angle="180" basePoint="2" id="56" length="#WaistCircumference/4 + #BackDartWidth - #BackCenterShift" lineColor="black" lineType="none" mx="0.5" my="-1.5" name="WaistBSide" type="endLine" />
            <line firstPoint="56" id="57" lineColor="black" lineType="solidLine" secondPoint="55" />
            <point firstPoint="56" id="58" length="Line_WaistBSide_WaistBCB/2" lineColor="black" lineType="none" mx="0.5" my="-1.5" name="DartCenterB" secondPoint="55" type="alongLine" />
            <point firstPoint="58" id="59" length="#BackDartWidth/2" lineColor="black" lineType="none" mx="0.5" my="-1.5" name="DartBL1" secondPoint="56" type="alongLine" />
            <point firstPoint="58" id="60" length="#BackDartWidth/2" lineColor="black" lineType="none" mx="0.5" my="-1.5" name="DartBL2" secondPoint="55" type="alongLine" />
            <point angle="180" firstPoint="58" id="61" length="#BackDartDepth" lineColor="black" lineType="none" mx="0.5" my="-1.5" name="DartTipB" secondPoint="55" type="normal" />
            <point angle="270" basePoint="51" id="62" length="(#HipLineHeight - #CrotchHeight)/2" lineColor="black" lineType="none" mx="0.5" my="-1.5" name="CtrlBCrotch1" type="endLine" />
            <point angle="180" basePoint="53" id="63" length="#FrontCrotchHookWidth/1.2" lineColor="black" lineType="none" mx="0.5" my="-1.5" name="CtrlBCrotch2" type="endLine" />
            <spline color="black" id="64" point1="51" point2="62" point3="63" point4="53" type="cubicBezier" />
            <point angle="270" basePoint="56" id="65" length="(#WaistHeight - #HipLineHeight)/2" lineColor="black" lineType="none" mx="0.5" my="-1.5" name="CtrlBSide1" type="endLine" />
            <point angle="90" basePoint="52" id="66" length="(#WaistHeight - #HipLineHeight)/3" lineColor="black" lineType="none" mx="0.5" my="-1.5" name="CtrlBSide2" type="endLine" />
            <spline color="black" id="67" point1="56" point2="65" point3="66" point4="52" type="cubicBezier" />
            <line firstPoint="55" id="68" lineColor="black" lineType="solidLine" secondPoint="51" />
            <line firstPoint="49" id="69" lineColor="black" lineType="solidLine" secondPoint="53" />
            <line firstPoint="52" id="70" lineColor="black" lineType="solidLine" secondPoint="50" />
            <line firstPoint="50" id="71" lineColor="black" lineType="solidLine" secondPoint="48" />
            <line firstPoint="48" id="72" lineColor="black" lineType="solidLine" secondPoint="47" />
            <line firstPoint="47" id="73" lineColor="black" lineType="solidLine" secondPoint="49" />
        </calculation>
        <modeling>
            <point id="32" idObject="13" inUse="true" mx="0.1" my="0.2" type="modeling" />
            <point id="33" idObject="18" inUse="true" mx="0.1" my="0.2" type="modeling" />
