            <point id="87" idObject="51" inUse="true" mx="0.1" my="0.2" type="modeling" />
        </modeling>
        <pieces>
            <piece closed="1" id="46" mx="0" my="0" name="TrousersFront" seamAllowance="1" version="2" width="1">
                <data annotation="" foldPosition="" fontSize="0" height="5" letter="F" mx="-10" my="-70" onFold="false" orientation="" quantity="2" rotation="0" rotationWay="" tilt="" visible="true" width="12">
                    <line alignment="0" bold="true" italic="false" sfIncrement="2" text="Trousers Front" />
                    <line alignment="0" bold="false" italic="false" sfIncrement="0" text="cut 2" />
                </data>
                <patternInfo fontSize="0" height="" mx="0" my="0" rotation="" visible="false" width="" />
