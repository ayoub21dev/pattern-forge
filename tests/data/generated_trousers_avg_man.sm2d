    <draftBlock name="Waistband">
        <calculation>
            <point id="89" mx="0.5" my="-1.5" name="WbA" type="single" x="0" y="0" />
            <point angle="0" basePoint="89" id="90" length="#WaistCircumference + 4" lineColor="black" lineType="solidLine" mx="0.5" my="-1.5" name="WbB" type="endLine" />
            <point angle="270" basePoint="90" id="91" length="#WaistBandWidth*2" lineColor="black" lineType="solidLine" mx="0.5" my="-1.5" name="WbC" type="endLine" />
            <point angle="270" basePoint="89" id="92" length="#WaistBandWidth*2" lineColor="black" lineType="solidLine" mx="0.5" my="-1.5" name="WbD" type="endLine" />
            <line firstPoint="91" id="93" lineColor="black" lineType="solidLine" secondPoint="92" />
