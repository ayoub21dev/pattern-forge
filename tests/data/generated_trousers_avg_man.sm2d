            <point id="78" idObject="56" inUse="true" mx="0.1" my="0.2" type="modeling" />
            <spline id="79" idObject="67" inUse="true" type="modelingSpline" />
            <point id="80" idObject="52" inUse="true" mx="0.1" my="0.2" type="modeling" />
            <point id="81" idObject="50" inUse="true" mx="0.1" my="0.2" type="modeling" />
